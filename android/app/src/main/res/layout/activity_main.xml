<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PoseDetectionActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewCam"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.ooplab.exercises_fitfuel.PoseOverlayView
        android:id="@+id/poseOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Persistent tilt indicator — always visible regardless of phase -->
    <TextView
        android:id="@+id/tvTiltStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● Tilt  --°"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:background="#AA000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Rotation indicator — always visible, checks phone is level (roll ≈ 0°) -->
    <TextView
        android:id="@+id/tvRotationStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● Rotation  --"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:background="#AA000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTiltStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Distance indicator — updated during POSE phase, shows placeholder otherwise -->
    <TextView
        android:id="@+id/tvDistanceStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● Distance  --"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:background="#AA000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvRotationStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Side view indicator — visible during POSE phase -->
    <TextView
        android:id="@+id/tvSideViewStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● Side  --"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:background="#AA000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDistanceStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Capture sequence cue — visible during POSE phase once the multi-shot
         capture sequence starts; tells the phone holder what's happening. -->
    <TextView
        android:id="@+id/tvCaptureStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="14sp"
        android:gravity="center"
        android:background="#CC1A1A1A"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="40dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvSideViewStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status panel — visible during LIGHT_CHECK and DETECTING phases -->
    <LinearLayout
        android:id="@+id/detectionPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC1A1A1A"
        android:paddingHorizontal="32dp"
        android:paddingVertical="18dp"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="14dp" />

        <!-- Light indicator -->
        <TextView
            android:id="@+id/tvLightStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Light"
            android:textColor="#9E9E9E"
            android:textSize="15sp"
            android:layout_marginBottom="10dp" />

        <!-- Person + Monitor indicators -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPersonStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Person"
                android:textColor="#9E9E9E"
                android:textSize="15sp"
                android:layout_marginEnd="28dp" />

            <TextView
                android:id="@+id/tvMonitorStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Monitor"
                android:textColor="#9E9E9E"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Confirmation progress — appears when both person + monitor detected -->
        <ProgressBar
            android:id="@+id/confirmProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="160dp"
            android:layout_height="6dp"
            android:layout_marginTop="16dp"
            android:max="4"
            android:progress="0"
            android:progressTint="#43A047"
            android:progressBackgroundTint="#33FFFFFF"
            android:visibility="invisible" />

        <!-- General status message: light guidance, "Hold still...", "Loading..." -->
        <TextView
            android:id="@+id/tvStatusMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSwitchCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Switch Camera"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Reset"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Shutter flash — brief white flash overlay fired on each capture -->
    <View
        android:id="@+id/flashOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FFFFFFFF"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
